# ── Required ────────────────────────────────────────────────
# Groq API key (free tier available at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Optional: Email confirmations ───────────────────────────
# Gmail address used to send booking confirmation emails
GMAIL_ADDRESS=your_email@gmail.com

# Gmail App Password (enable 2‑factor authentication, then generate at
# https://myaccount.google.com/apppasswords)
GMAIL_APP_PASSWORD=your_16_character_app_password

# ── Optional: LangSmith tracing ─────────────────────────────
# Enable to see agent traces at https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your_langsmith_api_key
# LANGCHAIN_PROJECT=MedicalAgent

# ── Optional: Twilio SMS reminders ───────────────────────────
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890